pipeline {
    agent any

    environment {
        SERVER_IP = "13.58.255.150"
    }

    stages {

        stage('Deploy Node App') {
            steps {
                sh '''
                ssh -o StrictHostKeyChecking=no ubuntu@$13.58.255.150 "
                
                if [ ! -d simple-nodejs-app ]; then
                    git clone https://github.com/Nitya-vadoni/simple-nodejs-app.git
                fi

                cd simple-nodejs-app

                git pull origin main

                docker build -t nodeapp .

                docker stop nodeapp || true
                docker rm nodeapp || true

                docker run -d -p 3000:3000 --name nodeapp nodeapp
                "
                '''
            }
        }

    }
}
