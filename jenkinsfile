pipeline {
    agent any

    stages {
        stage('Deploy to Node VM') {
            steps {
                sh '''
                ssh -o StrictHostKeyChecking=no ubuntu@98.93.1.161 "
                    cd /home/ubuntu/simple-nodejs-app &&
                    git pull origin main &&
                    npm install &&
                    pm2 restart nodeapp || pm2 start index.js --name nodeapp
                "
                '''
            }
        }
    }
}
