pipeline {
    agent any

    environment {
        DOCKERHUB_CREDENTIALS = 'dockerhub-creds-id'
        DOCKER_USER = 'your_dockerhub_username'
        NODE_IMAGE = "${DOCKER_USER}/node-app"
        NGINX_IMAGE = "${DOCKER_USER}/nginx-proxy"
        VM_IP = "YOUR_VM_PUBLIC_IP"
        VM_USER = "ubuntu"
    }

    stages {

        stage('Clone Code') {
            steps {
                git 'https://github.com/your-repo.git'
            }
        }

        stage('Build Node Image') {
            steps {
                sh 'docker build -t $NODE_IMAGE ./node-app'
            }
        }

        stage('Build Nginx Image') {
            steps {
                sh 'docker build -t $NGINX_IMAGE ./nginx'
            }
        }

        stage('Login to DockerHub') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: DOCKERHUB_CREDENTIALS,
                    usernameVariable: 'USER',
                    passwordVariable: 'PASS'
                )]) {
                    sh 'echo $PASS | docker login -u $USER --password-stdin'
                }
            }
        }

        stage('Push Images') {
            steps {
                sh '''
                docker push $NODE_IMAGE
                docker push $NGINX_IMAGE
                '''
            }
        }

        stage('Deploy to VM') {
            steps {
                sshagent(['vm-ssh-key']) {
                    sh """
                    ssh -o StrictHostKeyChecking=no $VM_USER@$VM_IP << EOF

                    docker pull $NODE_IMAGE
                    docker pull $NGINX_IMAGE

                    docker rm -f nodeapp || true
                    docker rm -f nginx || true

                    docker network create app-net || true

                    docker run -d --name nodeapp \
                        --network app-net \
                        $NODE_IMAGE

                    docker run -d --name nginx \
                        --network app-net \
                        -p 80:80 \
                        $NGINX_IMAGE

                    EOF
                    """
                }
            }
        }
    }
}
